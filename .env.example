# AutoLedger — environment configuration
# ========================================
# This file is read automatically by docker compose.
# Edit DATA_PATH to match your host machine — everything else stays the same.

# ── Mac (default) ─────────────────────────────────────────────────────────────
# Stores data in a ./data/ folder next to this file. No changes needed.
DATA_PATH=./data

# ── Synology NAS ──────────────────────────────────────────────────────────────
# Comment out the Mac line above and uncomment this one instead:
# DATA_PATH=/volume1/docker/autoledger/data

# ── Logging (optional) ────────────────────────────────────────────────────────
# Log verbosity for the structured stdout logger. INFO (default) or DEBUG.
# LOG_LEVEL=INFO

# ── Notification secrets — OPTIONAL pre-seeding (v2.0.0) ───────────────────────
# Everything below is OPTIONAL. The recommended path is to leave these blank and
# configure email / Home Assistant in the app's Settings page, where secrets are
# encrypted at rest. These vars only PRE-SEED the config on a brand-new data
# volume (first run); on first save they are encrypted into data/notify.json and
# the env vars are no longer consulted. Never commit real secrets to this file.
#
# Email (SMTP / STARTTLS, port 587). Resend example shown.
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USERNAME=resend
# SMTP_PASSWORD=                  # Resend API key, or Gmail app password
# SMTP_FROM=autoledger@yourdomain.example
# SMTP_TO=you@example.com
#
# Home Assistant. Create a long-lived access token in HA → Profile → Security.
# HA_BASE_URL=http://192.168.0.200:8123
# HA_TOKEN=
# HA_NOTIFY_SERVICE=             # optional, e.g. notify.mobile_app_phone

# ── Scheduler (tests only) ────────────────────────────────────────────────────
# Set to 1 to disable the in-process daily reminder scheduler. Used by the test
# suite; not needed in normal operation.
# AUTOLEDGER_DISABLE_SCHEDULER=0
