# AutoLedger — environment configuration
# ========================================
# This file is read automatically by docker compose.
# Edit DATA_PATH to match your host machine — everything else stays the same.

# ── Mac (default) ─────────────────────────────────────────────────────────────
# Stores data in a ./data/ folder next to this file. No changes needed.
DATA_PATH=./data

# ── Synology NAS ──────────────────────────────────────────────────────────────
# Comment out the Mac line above and uncomment this one instead:
# DATA_PATH=/volume1/docker/autoledger/data
